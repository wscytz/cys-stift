{
  "name": "cys-stift",
  "version": "1.1.0-preview.3",
  "private": true,
  "description": "cy's Stift — 本地优先的灵感画布",
  "author": "cy",
  "license": "GPL-3.0-or-later",
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm -r build",
    "lint": "pnpm -r lint",
    "test": "pnpm -r test",
    "benchmark:intent": "pnpm --filter web test -- src/features/ai/__tests__/intent-benchmark.test.ts src/features/ai/__tests__/intent-compiler.test.ts",
    "benchmark:proposal": "pnpm --filter web test -- src/features/ai/coauthor/__tests__/proposal-benchmark.test.ts",
    "smoke:proposal": "node scripts/smoke-proposal-coauthor.mjs",
    "docs:links": "node scripts/check-doc-links.mjs",
    "tauri": "pnpm --filter desktop tauri",
    "clean": "pnpm -r exec rm -rf .next out dist node_modules/.cache"
  },
  "devDependencies": {
    "prettier": "3.3.3",
    "puppeteer-core": "23.10.4",
    "typescript": "5.6.3"
  }
}
