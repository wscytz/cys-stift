# Force LF line endings everywhere; mark common binaries as binary.
*                 text=auto eol=lf
*.png             binary
*.jpg             binary
*.jpeg            binary
*.gif             binary
*.ico             binary
*.icns            binary
*.webp            binary
*.woff            binary
*.woff2           binary
*.ttf             binary
*.otf             binary
*.mp4             binary
*.webm            binary
*.mp3             binary
*.wav             binary
